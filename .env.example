# ParselBul ortam değişkenleri şablonu.
# Bu dosyayı .env olarak kopyalayın ve Hostinger MySQL bilgilerinizi girin.
# .env dosyası ASLA commit edilmez (.gitignore içinde).

# Sunucu
PORT=3000

# Hostinger MySQL veritabanı (bilgiler sonradan eklenecek)
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Oturum (session) gizli anahtarı — rastgele uzun bir değer girin
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
